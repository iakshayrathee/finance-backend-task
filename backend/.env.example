# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection strings
DATABASE_URL=postgresql://user:password@localhost:5432/
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/testdb

# ── JWT ────────────────────────────────────────────────────────────────────────
# Use at least 32 random characters for each secret
JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
